<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    @* <partial name="_StylePartial" /> *@
    @* <link rel="stylesheet" href="~/css/base.css" /> *@
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @* <link rel="stylesheet" href="~/css/styles.css" /> *@
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container" style="margin: 5vh">
                <a class="navbar-brand" href="https://o-iva.ru/">Перейти на сайт</a>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

     <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2020-2025 - GlebB                  
        </div>
    </footer>
    @* <a asp-area="" asp-page="/Privacy">Privacy</a> *@

    @await RenderSectionAsync("Portal", required: false)
   
    @* <script src="~/lib/jquery/dist/jquery.min.js"></script> *@
    @* <partial name="_ScriptPartial" /> *@
    
    @* <script asp-src-include="@(ViewContext.View.Path).js"></script> *@
    @* <script src="~/lib/jquery/dist/jquery.min.js"></script> *@
    @* <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> *@
    @* <script src="~/js/site.js" asp-append-version="true"></script> *@

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>